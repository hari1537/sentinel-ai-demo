# Backend Configuration (.env.example)
# Copy this to .env and fill in your actual values

MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/sentinel-ai?retryWrites=true&w=majority
JWT_SECRET=your-jwt-secret-key-change-this
ENCRYPTION_SECRET=your-encryption-secret-key-change-this
PORT=5000

# Mailgun Email Configuration
MAILGUN_API_KEY=key-your-api-key-from-mailgun
MAILGUN_DOMAIN=mg.sentinel-ai.com

# Optional: Vercel Deployment
VERCEL_ENV=production
